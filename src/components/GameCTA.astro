---
import TicTacToe from './TicTacToe.astro';
---

<div class="game-inner reveal">
  <div class="game-text">
    <p class="game-desc">I made a totally fair game of Tic-Tac-Toe. No cheating. Definitely no cheating. If you win, you don't have to hire me.</p>
    <p class="game-disclaimer">(You won't win.)</p>
  </div>
  <TicTacToe />
</div>

<style>
  .game-inner {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .game-text {
    max-width: 520px;
  }

  .game-desc {
    color: var(--fg-body);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 8px;
  }

  .game-disclaimer {
    color: var(--fg-muted);
    font-size: 0.85rem;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .game-text {
      text-align: center;
      max-width: none;
    }
  }
</style>
