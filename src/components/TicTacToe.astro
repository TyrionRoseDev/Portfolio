  // ── Signature Canvas ──
  const sigCanvas = document.getElementById('sigCanvas');
  const sigCtx = sigCanvas.getContext('2d');
  let sigDrawing = false;

  function initSignatureCanvas() {
    const rect = sigCanvas.getBoundingClientRect();
    sigCanvas.width = rect.width * window.devicePixelRatio;
    sigCanvas.height = rect.height * window.devicePixelRatio;
    sigCtx.scale(window.devicePixelRatio, window.devicePixelRatio);
    sigCtx.strokeStyle = '#2c1810';
    sigCtx.lineWidth = 2;
    sigCtx.lineCap = 'round';
    sigCtx.lineJoin = 'round';
  }

  function clearSignature() {
    initSignatureCanvas();
    sigCtx.clearRect(0, 0, sigCanvas.width, sigCanvas.height);
  }

  function getSigPos(e) {
    const rect = sigCanvas.getBoundingClientRect();
    const touch = e.touches ? e.touches[0] : e;
    return { x: touch.clientX - rect.left, y: touch.clientY - rect.top };
  }

  sigCanvas.addEventListener('mousedown', (e) => {
    sigDrawing = true;
    const pos = getSigPos(e);
    sigCtx.beginPath();
    sigCtx.moveTo(pos.x, pos.y);
  });
  sigCanvas.addEventListener('mousemove', (e) => {
    if (!sigDrawing) return;
    const pos = getSigPos(e);
    sigCtx.lineTo(pos.x, pos.y);
    sigCtx.stroke();
  });
  sigCanvas.addEventListener('mouseup', () => { sigDrawing = false; });
  sigCanvas.addEventListener('mouseleave', () => { sigDrawing = false; });

  sigCanvas.addEventListener('touchstart', (e) => {
    e.preventDefault();
    sigDrawing = true;
    const pos = getSigPos(e);
    sigCtx.beginPath();
    sigCtx.moveTo(pos.x, pos.y);
  });
  sigCanvas.addEventListener('touchmove', (e) => {
    e.preventDefault();
    if (!sigDrawing) return;
    const pos = getSigPos(e);
    sigCtx.lineTo(pos.x, pos.y);
    sigCtx.stroke();
  });
  sigCanvas.addEventListener('touchend', () => { sigDrawing = false; });

  window.addEventListener('resize', createCellOverlays);

  // ── Drawing Marks ──
  async function drawX(cellIndex, animate = true) {
    const row = Math.floor(cellIndex / 3);
    const col = cellIndex % 3;
    const cx = col * 120 + 60;
    const cy = row * 120 + 60;
    const size = 28;
    const off = 5;

    const g = document.createElementNS(NS, 'g');
    g.classList.add('mark-x');
    g.dataset.cell = cellIndex;

    // Sketchy X using quadratic bezier curves for wobble
    const x1s = cx - size + wobble(0, off);
    const y1s = cy - size + wobble(0, off);
    const x1e = cx + size + wobble(0, off);
    const y1e = cy + size + wobble(0, off);
    const x1m = (x1s + x1e) / 2 + wobble(0, 8);
    const y1m = (y1s + y1e) / 2 + wobble(0, 8);

    const x2s = cx + size + wobble(0, off);
    const y2s = cy - size + wobble(0, off);
    const x2e = cx - size + wobble(0, off);
    const y2e = cy + size + wobble(0, off);
    const x2m = (x2s + x2e) / 2 + wobble(0, 8);
    const y2m = (y2s + y2e) / 2 + wobble(0, 8);

    const strokes = [
      `M ${x1s} ${y1s} Q ${x1m} ${y1m} ${x1e} ${y1e}`,
      `M ${x2s} ${y2s} Q ${x2m} ${y2m} ${x2e} ${y2e}`,
    ];

    strokes.forEach((d) => {
      const path = document.createElementNS(NS, 'path');
      path.setAttribute('d', d);
      path.classList.add('mark-path');
      g.appendChild(path);
    });

    boardSvg.appendChild(g);

    if (animate) {
      const paths = g.querySelectorAll('.mark-path');
      const drawDuration = 1000; // ms per stroke
      const strokeGap = 300;   // ms between strokes

      paths.forEach((path, i) => {
        const len = path.getTotalLength();
        path.style.strokeDasharray = len;
        path.style.strokeDashoffset = len;
        path.style.animation = `pencilDraw ${drawDuration}ms ${i * (drawDuration + strokeGap)}ms ease-out forwards`;
      });

      // Animate pencil along the paths
      pencilEl.classList.remove('eraser-mode');
      showPencil();

      for (let i = 0; i < paths.length; i++) {
        if (i > 0) await delay(strokeGap);
        await animatePencilAlongPath(paths[i], drawDuration);
      }
      hidePencil();
    }

    return g;
  }

  async function drawO(cellIndex, animate = true) {
    const row = Math.floor(cellIndex / 3);
    const col = cellIndex % 3;
    const cx = col * 120 + 60;
    const cy = row * 120 + 60;
    const r = 30;

    const g = document.createElementNS(NS, 'g');
    g.classList.add('mark-o');
    g.dataset.cell = cellIndex;

    // Wobbly circle using multiple bezier arcs for sketchiness
    const w = () => wobble(0, 4);
    const d = `M ${cx} ${cy - r + w()}
      C ${cx + r * 0.6 + w()} ${cy - r + w()}, ${cx + r + w()} ${cy - r * 0.4 + w()}, ${cx + r + w()} ${cy + w()}
      C ${cx + r + w()} ${cy + r * 0.5 + w()}, ${cx + r * 0.5 + w()} ${cy + r + w()}, ${cx + w()} ${cy + r + w()}
      C ${cx - r * 0.5 + w()} ${cy + r + w()}, ${cx - r + w()} ${cy + r * 0.5 + w()}, ${cx - r + w()} ${cy + w()}
      C ${cx - r + w()} ${cy - r * 0.4 + w()}, ${cx - r * 0.6 + w()} ${cy - r + w()}, ${cx + w()} ${cy - r + w()}`;

    const path = document.createElementNS(NS, 'path');
    path.setAttribute('d', d);
    path.classList.add('mark-path');
    g.appendChild(path);
    boardSvg.appendChild(g);

    if (animate) {
      const len = path.getTotalLength();
      const drawDuration = 2000;
      path.style.strokeDasharray = len;
      path.style.strokeDashoffset = len;
      path.style.animation = `pencilDraw ${drawDuration}ms ease-out forwards`;

      // Animate pencil along the circle
      pencilEl.classList.remove('eraser-mode');
      showPencil();
      await animatePencilAlongPath(path, drawDuration);
      hidePencil();
    }

    return g;
  }

  function eraseCell(cellIndex) {
    return new Promise(async (resolve) => {
      const mark = boardSvg.querySelector(`[data-cell="${cellIndex}"]`);
      if (!mark) { resolve(); return; }

      // Start fading the mark while the eraser scrubs
      mark.querySelectorAll('.mark-path').forEach(path => {
        path.style.animation = 'none';
        path.style.strokeDashoffset = '0';
        path.getBoundingClientRect();
        path.style.transition = 'opacity 1.5s ease-in';
        path.style.opacity = '0.15';
      });

      // Animate eraser scrubbing over the cell
      const scrubDuration = 1800;
      await animateEraserScrub(cellIndex, scrubDuration);

      // Final fade out
      mark.querySelectorAll('.mark-path').forEach(path => {
        path.style.transition = 'opacity 0.4s ease-out';
        path.style.opacity = '0';
      });

      await delay(450);
      mark.remove();
      hidePencil();
      resolve();
    });
  }

  // ── Commentary ──
  const commentaryEl = document.getElementById('commentary');

  function setCommentary(text) {
    commentaryEl.style.opacity = 0;
    setTimeout(() => {
      commentaryEl.textContent = text;
      commentaryEl.style.opacity = 1;
    }, 200);
  }

  function resetGame() {
    state.board = Array(9).fill(EMPTY);
    state.playerMoveCount = 0;
    state.gameOver = false;
    state.locked = false;
    state.cheatsUsed = [];

    boardSvg.querySelectorAll('.mark-x, .mark-o').forEach(el => el.remove());
    boardContainer.classList.remove('flipped');
    boardContainer.classList.remove('expanded');
    boardSvg.setAttribute('viewBox', '0 0 360 360');

    drawGrid();
    createCellOverlays();

    if (state.round === 2) {
      setCommentary("I gave myself a tiny head start.");
      const prePlaced = [0, 8];
      prePlaced.forEach(i => {
        state.board[i] = AI;
        drawO(i, true);
        markCellTaken(i);
      });
    } else if (state.round === 3) {
      setCommentary("This is definitely fair.");
      const prePlaced = [0, 2, 4, 6, 8];
      prePlaced.forEach(i => {
        state.board[i] = AI;
        drawO(i, true);
        markCellTaken(i);
      });
    } else if (state.round >= 4) {
      setCommentary("Speedrun.");
      state.locked = true;
      setTimeout(async () => {
        await cheatNuke();
      }, 500);
    } else {
      setCommentary('Your move!');
    }

    document.getElementById('roundNum').textContent = state.round;
    document.getElementById('winCount').textContent = '0';
  }

  // ── Init ──
  drawGrid();
  createCellOverlays();
  setCommentary('Your move!');
</script>
