      base.salary = '\u00a310,000,000/year';
      base.terms.find(t => t.label === 'Salary').value = '\u00a310,000,000/year (non-negotiable)';
      base.terms.push({ label: 'Transport', value: 'Private jet (for commuting to the home office)' });
      base.terms.push({ label: 'Catering', value: 'Personal chef provided' });
    } else if (round >= 4) {
      base.admission = "I lost a totally fair game of Tic-Tac-Toe (I don't know why I keep trying) and am now legally obligated to offer Tyrion a job.";
      base.salary = '\u00a3999,999,999/year';
      base.terms.find(t => t.label === 'Salary').value = '\u00a3999,999,999/year (non-negotiable)';
      base.terms.push({ label: 'Transport', value: 'Private jet (for commuting to the home office)' });
      base.terms.push({ label: 'Catering', value: 'Personal chef provided' });
